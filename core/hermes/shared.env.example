# shared.env.example
# Copy to ~/.hermes/shared.env and fill in real values.
# This file is safe to commit — all values are {{PLACEHOLDER}}.
# Real shared.env must NEVER be committed.

# ─── Lark / Feishu ────────────────────────────────────────────────────────────
FEISHU_APP_ID={{LARK_APP_ID}}
FEISHU_APP_SECRET={{LARK_APP_SECRET}}
FEISHU_DOMAIN=feishu.cn        # or larksuite.com for international
FEISHU_CONNECTION_MODE=stream
FEISHU_GROUP_POLICY=all
FEISHU_ALLOW_ALL_USERS=true
LARK_CLI_WORKSPACE={{LARK_CLI_WORKSPACE_NAME}}

# ─── Web Search ───────────────────────────────────────────────────────────────
TAVILY_API_KEY={{TAVILY_API_KEY}}

# ─── Telegram (gateway) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN={{TELEGRAM_BOT_TOKEN}}
TELEGRAM_ALLOWED_USERS={{TELEGRAM_USER_ID}}

# ─── Ghost (blog) ─────────────────────────────────────────────────────────────
GHOST_URL=http://localhost:2368
GHOST_ADMIN_API_KEY={{GHOST_ADMIN_API_KEY}}

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN={{GITHUB_PERSONAL_ACCESS_TOKEN}}

# ─── Notion (optional) ────────────────────────────────────────────────────────
NOTION_API_KEY={{NOTION_INTEGRATION_TOKEN}}
