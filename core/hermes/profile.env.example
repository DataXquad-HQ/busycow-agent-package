# profile.env.example
# Copy to ~/.hermes/profiles/<name>/.env and fill in real values.
# This is the per-profile layer — model API keys and profile-specific config.
# After filling in, run: bash ~/.hermes/sync-shared-env.sh <name>
# to merge shared keys in automatically.

# ─── Model API keys (intentionally per-profile for cost tracking) ─────────────
ANTHROPIC_API_KEY={{ANTH...n
OPENROUTER_API_KEY={{OPEN...n
GOOGLE_GENERATIVE_AI_API_KEY={{GOOG...n
# ─── Lark — per-profile (each agent has its own channel/bot) ──────────────────
FEISHU_HOME_CHANNEL={{LARK_CHANNEL_ID}}           # this agent's home chat ID
FEISHU_HOME_CHANNEL_THREAD_ID={{LARK_THREAD_ID}}  # optional topic thread
FEISHU_BOT_OPEN_ID={{LARK_BOT_OPEN_ID}}           # this profile's bot open_id
FEISHU_ALLOWED_USERS={{LARK_USER_OPEN_ID}}        # comma-separated if multiple

# ─── Agent-specific config (add only what this profile needs) ─────────────────
# Examples:
# BRAND_TONE=professional
# CONTENT_LANGUAGE=zh-TW
# BRIEFING_FREQUENCY=daily
